{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        }
      ]
    }
  ],

  "rewrites": [
    {
      "source": "/country/:name",
      "destination": "/country.html?c=:name"
    }
  ]
}
